# Frontend Environment Variables (Vite)
# Variables must be prefixed with VITE_ to be exposed to client-side code
# Copy this file to .env.local for local development

# Backend API URL
# Development: http://localhost:5000
# Production: https://backend-chat.onrender.com (UPDATE WITH YOUR ACTUAL BACKEND URL)
VITE_API_BASE_URL=https://koretalk007.onrender.com

# Socket.io Server URL
# Should be same as backend URL for production
VITE_SOCKET_URL=https://koretalk007.onrender.com

# Firebase Configuration (optional - if you want to move from hardcoded config)
# VITE_FIREBASE_API_KEY=your-api-key
# VITE_FIREBASE_AUTH_DOMAIN=your-auth-domain
# VITE_FIREBASE_PROJECT_ID=your-project-id
# VITE_FIREBASE_STORAGE_BUCKET=your-storage-bucket
# VITE_FIREBASE_MESSAGING_SENDER_ID=your-messaging-sender-id
# VITE_FIREBASE_APP_ID=your-app-id

# Environment
VITE_NODE_ENV=development
